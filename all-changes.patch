@@ -0,0 +1,42 @@
+package eg.com.mdi.routes.carddelivery.processors;
+
+import lombok.extern.log4j.Log4j2;
+import org.apache.camel.Exchange;
+import org.apache.camel.Processor;
+import org.springframework.stereotype.Component;
+
+import java.io.IOException;
+import java.nio.file.Files;
+import java.nio.file.Path;
+import java.nio.file.Paths;
+
+@Log4j2
+@Component
+public class SourceFileCleanupProcessor implements Processor {
+    static final String CAMEL_FILE_ABSOLUTE_PATH = "CamelFileAbsolutePath";
+
+    @Override
+    public void process(Exchange exchange) throws IOException {
+        Path sourceFilePath = resolveSourceFilePath(exchange);
+        if (sourceFilePath == null) {
+            return;
+        }
+        if (!Files.isRegularFile(sourceFilePath)) {
+            log.warn("Skipping source file cleanup because path is not a regular file: {}", sourceFilePath);
+            return;
+        }
+        Files.deleteIfExists(sourceFilePath);
+        log.info("Deleted source file after terminal processing: {}", sourceFilePath);
+    }
+
+    private Path resolveSourceFilePath(Exchange exchange) {
+        Object sourcePath = exchange.getIn().getHeader(CAMEL_FILE_ABSOLUTE_PATH);
+        if (sourcePath == null) {
+            sourcePath = exchange.getIn().getHeader(Exchange.FILE_PATH);
+        }
+        if (sourcePath == null || sourcePath.toString().isBlank()) {
+            return null;
+        }
+        return Paths.get(sourcePath.toString());
+    }
+}
