+package eg.com.mdi.batch.util;
+
+import org.junit.jupiter.api.Test;
+import org.junit.jupiter.api.io.TempDir;
+import org.springframework.batch.item.ExecutionContext;
+
+import java.nio.charset.StandardCharsets;
+import java.nio.file.Files;
+import java.nio.file.Path;
+import java.util.Map;
+
+import static org.junit.jupiter.api.Assertions.assertEquals;
+
+class FileRangePartitionerTest {
+
+    @TempDir
+    Path tempDir;
+
+    @Test
+    void shouldPartitionByCsvRecordsNotPhysicalLines() throws Exception {
+        Path file = tempDir.resolve("ABS_multiline.csv");
+        Files.writeString(file, """
+                h1,h2
+                value1,"line one
+                line two"
+                value2,value3
+                """, StandardCharsets.UTF_8);
+
+        Map<String, ExecutionContext> partitions = new FileRangePartitioner(file.toString(), 1).partition(1);
+
+        assertEquals(2, partitions.size());
+        assertEquals(0L, partitions.get("partition0").getLong("startLine"));
+        assertEquals(1L, partitions.get("partition0").getLong("endLine"));
+        assertEquals(1L, partitions.get("partition1").getLong("startLine"));
+        assertEquals(2L, partitions.get("partition1").getLong("endLine"));
+    }
+}
