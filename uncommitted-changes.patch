+import net.atos.mdi.commons.workflow.WorkflowExceptionHandler;
+import net.atos.mdi.commons.workflow.WorkflowStep;
+import net.atos.mdi.commons.workflow.exception.WorkflowException;
+
+public abstract class FundFromExternalCardParentStep implements WorkflowStep {
+
+    protected final String name;
+    protected FundWorkflowContext workflowContext;
+    protected WorkflowExceptionHandler exceptionHandler;
+
+    protected FundFromExternalCardParentStep(String name) {
+        this.name = name;
+    }
+
+    @Override
+    public String getName() {
+        return name;
+    }
+
+    @Override
+    public void setWorkflowContext(WorkflowContext workflowContext) {
+        if (workflowContext instanceof FundWorkflowContext context) {
+            this.workflowContext = context;
+        } else {
+            throw new WorkflowException("Invalid fund workflow context");
+        }
+    }
+
+    @Override
+    public WorkflowContext getWorkflowContext() {
+        return workflowContext;
+    }
+
+    @Override
+    public void setExceptionHandler(WorkflowExceptionHandler exceptionHandler) {
+        this.exceptionHandler = exceptionHandler;
+    }
+
+    @Override
+    public WorkflowExceptionHandler getExceptionHandler() {
+        return exceptionHandler;
+    }
+}
