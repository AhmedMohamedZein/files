+package net.atos.mdi.transfermanagement.services.workflow.fund.step;
+
+import net.atos.mdi.commons.util.CommonUtil;
+import net.atos.mdi.transfermanagement.constant.ErrorKeys;
+import net.atos.mdi.transfermanagement.utils.FundUtils;
+import net.atos.mdi.transfermanagement.web.api.vm.FundInitPayerRequest;
+import org.springframework.beans.factory.config.ConfigurableBeanFactory;
+import org.springframework.context.annotation.Scope;
+import org.springframework.stereotype.Component;
+
+@Component
+@Scope(ConfigurableBeanFactory.SCOPE_PROTOTYPE)
+public class PrepareFundInitPayerRequestStep extends FundFromExternalCardParentStep {
+
+    private final FundUtils fundUtils;
+    private final CommonUtil commonUtil;
+
+    public PrepareFundInitPayerRequestStep(FundUtils fundUtils, CommonUtil commonUtil) {
+        super("PrepareFundInitPayerRequestStep");
+        this.fundUtils = fundUtils;
+        this.commonUtil = commonUtil;
+    }
+
+    @Override
+    public void execute() {
+        try {
+            String customerExternalCard = fundUtils.getCustomerExternalCard(workflowContext.getInitPayerRequestV2(), workflowContext.getCommonSecret());
+            FundInitPayerRequest request = fundUtils.mapToFundInitPayerRequest(workflowContext.getInitPayerRequestV2(), customerExternalCard);
+            request = fundUtils.decryptFundInitPayerRequest(request, workflowContext.getCommonSecret());
+            workflowContext.setFundingRequest(request);
+            workflowContext.setLanguage(fundUtils.getLanguage(workflowContext.getHeaders()));
+            workflowContext.setDeviceFingerprint(fundUtils.getDeviceFingerPrint(workflowContext.getHeaders()));
+        } catch (Exception e) {
+            commonUtil.throwBusinessException(ErrorKeys.GENERAL_ERROR_OCCURRED_WHILE_ENCRYPTING_DECRYPTING);
+        }
+    }
+}
