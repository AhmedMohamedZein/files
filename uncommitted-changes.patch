+@RestController
+@RequestMapping("${app.config.integration.domain.transfer-management.base-uri}")
+@Validated
+public class WorkflowFundController {
+
+    private final ErrorCodesLoader errorCodesLoader;
+    private final WorkflowFundService workflowFundService;
+
+    public WorkflowFundController(ErrorCodesLoader errorCodesLoader, WorkflowFundService workflowFundService) {
+        this.errorCodesLoader = errorCodesLoader;
+        this.workflowFundService = workflowFundService;
+    }
+
+    @PostMapping(value = "/v2/transfers/fund-external-card/init-payer", produces = MediaType.APPLICATION_JSON_VALUE)
+    @ResponseStatus(code = HttpStatus.OK)
+    @CustomApiResponse
+    @ApiResponse(responseCode = "200", description = "Success", headers = {
+            @Header(name = "X-Correlation-Id", description = "Request ID", schema = @Schema(type = "string")),
+            @Header(name = "Server", description = "fund my account from external card v2 workflow", schema = @Schema(type = "string"))
+    })
+    @Tag(name = "fund my account from external card", description = "Workflow based Initiate&AuthenticatePayer request")
+    public APIResponse<FundInitPayerResponse> externalFundInitiateAndAuthenticatePayer(Authentication authentication,
+                                                                                       @Validated @RequestBody FundInitPayerRequestV2 request,
+                                                                                       @RequestHeader Map<String, String> headers,
+                                                                                       @RequestHeader("commonSecret") String commonSecret)
+            throws InvalidAlgorithmParameterException, NoSuchPaddingException, IllegalBlockSizeException,
+            NoSuchAlgorithmException, BadPaddingException, InvalidKeyException {
+        AuthorizationDetails authorizationDetails = (AuthorizationDetails) authentication.getPrincipal();
+        Error error = errorCodesLoader.getErrorCodes().get(ErrorKeys.OK);
+        FundInitPayerResponse response = workflowFundService.initiateExternalCardFunding(request, headers,
+                authorizationDetails.getCustomerId(), commonSecret);
+        return new APIResponseBuilder<FundInitPayerResponse>().code(error.getCode()).reason(error.getReason()).addMessage(error.getReason()).body(response).build();
+    }
+
+    @PostMapping(value = "/v2/transfers/fund-external-card/apple-pay", produces = MediaType.APPLICATION_JSON_VALUE)
+    @ResponseStatus(code = HttpStatus.OK)
+    @CustomApiResponse
+    @ApiResponse(responseCode = "200", description = "Success", headers = {
+            @Header(name = "X-Correlation-Id", description = "Request ID", schema = @Schema(type = "string")),
+            @Header(name = "Server", description = "fund my account from external card via apple pay workflow", schema = @Schema(type = "string"))
+    })
+    @Tag(name = "fund my account from external card via apple pay", description = "Workflow based wallet funding")
+    public APIResponse<FundingResponse> externalFundViaApplePay(Authentication authentication,
+                                                                @Validated @RequestBody FundUsingApplePayRequest request,
+                                                                @RequestHeader Map<String, String> headers) throws JsonProcessingException {
+        AuthorizationDetails authorizationDetails = (AuthorizationDetails) authentication.getPrincipal();
+        Error error = errorCodesLoader.getErrorCodes().get(ErrorKeys.OK);
+        FundingResponse response = workflowFundService.fundUsingApplePay(request, headers, authorizationDetails.getCustomerId());
+        return new APIResponseBuilder<FundingResponse>().code(error.getCode()).reason(error.getReason()).addMessage(error.getReason()).body(response).build();
+    }
+
+    @PostMapping(value = "/v2/transfers/fund-external-card/pay", produces = MediaType.APPLICATION_JSON_VALUE)
+    @ResponseStatus(code = HttpStatus.OK)
+    @CustomApiResponse
+    @ApiResponse(responseCode = "200", description = "Success", headers = {
+            @Header(name = "X-Correlation-Id", description = "Request ID", schema = @Schema(type = "string")),
+            @Header(name = "Server", description = "Second Step account Payment gateway & internal transfer workflow", schema = @Schema(type = "string"))
+    })
+    @Tag(name = "Second Step account Payment gateway & internal transfer", description = "Workflow based second step funding")
+    public ResponseEntity<Object> externalFundPaymentAndInternalTransfer(WebRequest webRequest) {
+        String transactionId = webRequest.getParameter("transaction.id");
+        String orderId = webRequest.getParameter("order.id");
+        String result = webRequest.getParameter("result");
+        String gatewayRecommendation = webRequest.getParameter("response.gatewayRecommendation");
+        MerchantProviderRequest request = new MerchantProviderRequest(transactionId, orderId, result, gatewayRecommendation);
+        String url = workflowFundService.completeExternalCardFunding(request).getUrl();
+        return ResponseEntity.status(HttpStatus.FOUND).location(URI.create(url)).build();
+    }
+}
