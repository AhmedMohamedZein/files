+package net.atos.mdi.transfermanagement.services.workflow.fund.support;
+
+import lombok.RequiredArgsConstructor;
+import net.atos.mdi.commons.util.MaskingUtility;
+import net.atos.mdi.transfermanagement.constant.Constants;
+import net.atos.mdi.transfermanagement.constant.FundStatus;
+import net.atos.mdi.transfermanagement.entities.TransferDetails;
+import net.atos.mdi.transfermanagement.repository.TransactionRepository;
+import net.atos.mdi.transfermanagement.repository.entities.TransactionHistory;
+import org.springframework.stereotype.Component;
+
+@Component
+@RequiredArgsConstructor
+public class FundWorkflowResultSupport {
+
+    private final TransactionRepository transactionRepository;
+    private final MaskingUtility maskingUtility;
+
+    public void removeSensitiveTransactionInformation(TransactionHistory transactionHistory) {
+        transactionHistory.getFundInitPayerRequest().setCardPan(null);
+        transactionHistory.getFundInitPayerRequest().setCvv(null);
+        transactionHistory.getFundInitPayerRequest().setExpirationDate(null);
+    }
+
+    public String maskedCardNumber(TransferDetails transferDetails) {
+        return maskingUtility.maskCardNumberV2(transferDetails.getTransferRequest().getSourceIdentifier());
+    }
+
+    public void handleBackEndException(StringBuilder attributes, TransactionHistory transactionHistory, String transactionId) {
+        if (transactionHistory != null) {
+            handleGeneralErrorTransactionHistoryExists(attributes, transactionHistory);
+            removeSensitiveTransactionInformation(transactionHistory);
+            transactionRepository.saveTransaction(transactionHistory);
+        } else {
+            transactionDoesNotExist(attributes, transactionId);
+        }
+    }
+
+    public void successfulTransaction(StringBuilder attributes, TransactionHistory transactionHistory) {
+        attributes.append("?").append(Constants.TRANSACTION_ID).append("=").append(transactionHistory.getTransactionId());
+        attributes.append("&").append(Constants.STATUS).append(FundStatus.COMPLETED.value());
+        attributes.append("&").append(Constants.TRANSACTION_REFERENCE_PARAM).append(transactionHistory.getTransferSuspendAccountResponse().getTransactionReference());
+        attributes.append("&").append(Constants.AMOUNT_PARAM).append(transactionHistory.getFundInitPayerRequest().getAmount());
+        attributes.append("&").append(Constants.TRANSACTION_REFERENCE_NUMBER_PARAM).append(transactionHistory.getTransferSuspendAccountResponse().getReferenceNumber());
+        transactionHistory.setTransactionStatus(FundStatus.COMPLETED.name());
+    }
+
+    public void handleFundException(TransactionHistory transactionHistory, StringBuilder attributes) {
+        attributes.append("?").append(Constants.TRANSACTION_ID).append("=").append(transactionHistory.getTransactionId());
+        attributes.append("&").append(Constants.STATUS).append(FundStatus.FAILED.value());
+    }
+
+    public void unHandledException(StringBuilder attributes) {
+        attributes.append("?").append(Constants.STATUS).append(FundStatus.FAILED.value());
+    }
+
+    private void transactionDoesNotExist(StringBuilder attributes, String transactionId) {
+        attributes.append("?").append(Constants.TRANSACTION_ID).append("=").append(transactionId);
+        attributes.append("&").append(Constants.STATUS).append(FundStatus.FAILED.value());
+    }
+
+    private void handleGeneralErrorTransactionHistoryExists(StringBuilder attributes, TransactionHistory transactionHistory) {
+        attributes.append("?").append(Constants.TRANSACTION_ID).append("=").append(transactionHistory.getTransactionId());
+        attributes.append("&").append(Constants.AMOUNT_PARAM).append(transactionHistory.getAuthRequest().getOrder().getAmount());
+        attributes.append("&").append(Constants.STATUS).append(FundStatus.FAILED.value());
+        transactionHistory.setTransactionStatus(FundStatus.FAILED.name());
+    }
+}
