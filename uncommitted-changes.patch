+    private PrepareFundCallbackStep stubCallbackSteps() {
+        PrepareFundCallbackStep prepareStep = stubStep(PrepareFundCallbackStep.class);
+        stubStep(ValidateFundEligibilityStep.class);
+        stubStep(UpdateFundTransferLimitsStep.class);
+        stubStep(PayFundProviderStep.class);
+        stubStep(InternalFundTransferStep.class);
