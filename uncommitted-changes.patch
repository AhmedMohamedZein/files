+    private void stubWorkflow(String name) {
+        when(workflowStepFactory.getWorkflowStep(eq(DefaultWorkflow.class), eq(name), any(FundWorkflowContext.class)))
+                .thenAnswer(invocation -> {
+                    lastWorkflowContext = invocation.getArgument(2, FundWorkflowContext.class);
+                    return new DefaultWorkflow(name, lastWorkflowContext);
+                });
+    }
