+import net.atos.mdi.transfermanagement.services.workflow.fund.handler.FundPaymentFailureHandler;
+import net.atos.mdi.transfermanagement.services.workflow.fund.step.*;
+import net.atos.mdi.transfermanagement.services.workflow.fund.support.FundWorkflowResultSupport;
+import net.atos.mdi.transfermanagement.utils.FundUtils;
+import net.atos.mdi.transfermanagement.web.api.vm.FundInitPayerRequestV2;
+import net.atos.mdi.transfermanagement.web.api.vm.FundInitPayerResponse;
+import net.atos.mdi.transfermanagement.web.api.vm.FundUsingApplePayRequest;
+import net.atos.mdi.transfermanagement.web.api.vm.FundingResponse;
+import net.atos.mdi.transfermanagement.web.client.model.MerchantProviderRequest;
+import org.springframework.beans.factory.annotation.Value;
+import org.springframework.stereotype.Service;
+import org.springframework.web.servlet.view.RedirectView;
+
+import java.util.Map;
+
+@Service
+@RequiredArgsConstructor
+public class WorkflowFundServiceImpl implements WorkflowFundService {
+
+    private static final String FUND_INIT_PAYER_WORKFLOW = "FundInitPayerWorkflow";
+    private static final String FUND_PROVIDER_PAYMENT_WORKFLOW = "FundProviderPaymentWorkflow";
+    private static final String FUND_CALLBACK_PAYMENT_WORKFLOW = "FundCallbackPaymentWorkflow";
+
+    @Value("${app.config.integration.domain.transfer-management.payment-gateway.config.mobileRedirectResponseUrl}")
+    private String redirectResponseUrl;
+
+    private final WorkflowStepFactory workflowStepFactory;
+    private final TransactionRepository transactionRepository;
+    private final FundUtils fundUtils;
+    private final FundWorkflowResultSupport resultSupport;
+    private final CommonUtil commonUtil;
+
+    @Override
+    public FundInitPayerResponse initiateExternalCardFunding(FundInitPayerRequestV2 request, Map<String, String> headers, long customerId, String commonSecret) {
+        FundWorkflowContext context = FundWorkflowContext.builder()
+                .operation(FundWorkflowOperation.INIT_PAYER)
+                .fundingProvider(FundingProvider.EXTERNAL_CARD)
+                .initPayerRequestV2(request)
+                .headers(headers)
+                .customerId(customerId)
+                .commonSecret(commonSecret)
+                .correlationId(headers.get(Constants.X_CORRELATION_ID))
+                .build();
+        buildInitPayerWorkflow(context).execute();
+        return context.getInitPayerResponse();
+    }
+
+    @Override
+    public RedirectView completeExternalCardFunding(MerchantProviderRequest request) {
+        FundWorkflowContext context = FundWorkflowContext.builder()
+                .operation(FundWorkflowOperation.CALLBACK_PAYMENT)
+                .merchantProviderRequest(request)
+                .fundingProvider(FundingProvider.EXTERNAL_CARD)
+                .redirectAttributes(new StringBuilder())
+                .build();
+        try {
+            buildCallbackPaymentWorkflow(context).execute();
+            saveCallbackTransaction(context);
+        } catch (Exception e) {
+            handleCallbackException(context, e);
+        } finally {
+            fundUtils.clearRequestUtils();
+        }
+        return new RedirectView(fundUtils.getValidURL(redirectResponseUrl + context.getRedirectAttributes()));
+    }
+
+    @Override
+    public FundingResponse fundUsingApplePay(FundUsingApplePayRequest request, Map<String, String> headers, long customerId) {
+        FundWorkflowContext context = FundWorkflowContext.builder()
+                .operation(FundWorkflowOperation.PROVIDER_PAYMENT)
+                .fundingProvider(FundingProvider.APPLE_PAY)
+                .fundingRequest(request)
+                .headers(headers)
+                .customerId(customerId)
+                .correlationId(headers.get(Constants.X_CORRELATION_ID))
+                .build();
+        buildProviderPaymentWorkflow(context).execute();
+        return context.getFundingResponse();
+    }
+
+    private Workflow buildInitPayerWorkflow(FundWorkflowContext context) {
+        Workflow workflow = workflowStepFactory.getWorkflowStep(DefaultWorkflow.class, FUND_INIT_PAYER_WORKFLOW, context);
+        workflow.setExceptionHandler(new DefaultWorkflowExceptionHandler());
+        workflow.addStep(workflowStepFactory.getWorkflowStep(PrepareFundInitPayerRequestStep.class));
+        workflow.addStep(workflowStepFactory.getWorkflowStep(ValidateFundAmountStep.class));
+        workflow.addStep(workflowStepFactory.getWorkflowStep(ValidateFundFeesStep.class));
+        workflow.addStep(workflowStepFactory.getWorkflowStep(ValidateFundEligibilityStep.class));
+        workflow.addStep(workflowStepFactory.getWorkflowStep(CreateTransactionHistoryStep.class));
+        workflow.addStep(workflowStepFactory.getWorkflowStep(InitFundAuthenticationStep.class));
+        workflow.addStep(workflowStepFactory.getWorkflowStep(AuthenticateFundPayerStep.class));
+        workflow.addStep(workflowStepFactory.getWorkflowStep(MarkFundInitPayerInProgressStep.class));
+        return workflow;
+    }
+
+    private Workflow buildCallbackPaymentWorkflow(FundWorkflowContext context) {
+        Workflow workflow = workflowStepFactory.getWorkflowStep(DefaultWorkflow.class, FUND_CALLBACK_PAYMENT_WORKFLOW, context);
+        workflow.setExceptionHandler(new DefaultWorkflowExceptionHandler());
+        WorkflowExceptionHandler paymentFailureHandler = paymentFailureHandler(context);
+        workflow.addStep(workflowStepFactory.getWorkflowStep(PrepareFundCallbackStep.class));
+        workflow.addStep(workflowStepFactory.getWorkflowStep(ValidateFundEligibilityStep.class));
+        workflow.addStep(workflowStepFactory.getWorkflowStep(UpdateFundTransferLimitsStep.class));
+        workflow.addStep(workflowStepFactory.getWorkflowStep(PayFundProviderStep.class), paymentFailureHandler);
+        workflow.addStep(workflowStepFactory.getWorkflowStep(InternalFundTransferStep.class), paymentFailureHandler);
+        workflow.addStep(workflowStepFactory.getWorkflowStep(CompleteFundTransactionStep.class));
+        workflow.addStep(workflowStepFactory.getWorkflowStep(SaveFundTransactionStep.class));
+        return workflow;
+    }
+
+    private Workflow buildProviderPaymentWorkflow(FundWorkflowContext context) {
+        Workflow workflow = workflowStepFactory.getWorkflowStep(DefaultWorkflow.class, FUND_PROVIDER_PAYMENT_WORKFLOW, context);
+        workflow.setExceptionHandler(new DefaultWorkflowExceptionHandler());
+        WorkflowExceptionHandler paymentFailureHandler = paymentFailureHandler(context);
+        workflow.addStep(workflowStepFactory.getWorkflowStep(ValidateFundAmountStep.class));
+        workflow.addStep(workflowStepFactory.getWorkflowStep(ValidateFundFeesStep.class));
+        workflow.addStep(workflowStepFactory.getWorkflowStep(ValidateFundEligibilityStep.class));
+        workflow.addStep(workflowStepFactory.getWorkflowStep(CreateTransactionHistoryStep.class));
+        workflow.addStep(workflowStepFactory.getWorkflowStep(UpdateFundTransferLimitsStep.class));
+        workflow.addStep(workflowStepFactory.getWorkflowStep(PayFundProviderStep.class), paymentFailureHandler);
+        workflow.addStep(workflowStepFactory.getWorkflowStep(InternalFundTransferStep.class), paymentFailureHandler);
+        workflow.addStep(workflowStepFactory.getWorkflowStep(CompleteFundTransactionStep.class));
+        workflow.addStep(workflowStepFactory.getWorkflowStep(SaveFundTransactionStep.class));
+        return workflow;
+    }
+
+    private WorkflowExceptionHandler paymentFailureHandler(FundWorkflowContext context) {
+        return new FundPaymentFailureHandler(
+                context,
+                workflowStepFactory.getWorkflowStep(RollbackFundTransferLimitsStep.class),
+                workflowStepFactory.getWorkflowStep(RefundFundPaymentStep.class),
+                transactionRepository,
+                commonUtil
+        );
+    }
+
+    private void saveCallbackTransaction(FundWorkflowContext context) {
+        TransactionHistory transactionHistory = context.getTransactionHistory();
+        if (transactionHistory == null) {
+            return;
+        }
+        resultSupport.removeSensitiveTransactionInformation(transactionHistory);
+        transactionRepository.saveTransaction(transactionHistory);
+    }
+
+    private void handleCallbackException(FundWorkflowContext context, Exception e) {
+        commonUtil.logException(e);
+        TransactionHistory transactionHistory = context.getTransactionHistory();
+        if (transactionHistory != null && context.getRedirectAttributes().isEmpty()) {
+            resultSupport.handleFundException(transactionHistory, context.getRedirectAttributes());
+            resultSupport.removeSensitiveTransactionInformation(transactionHistory);
+            transactionRepository.saveTransaction(transactionHistory);
+        } else if (context.getRedirectAttributes().isEmpty()) {
+            resultSupport.unHandledException(context.getRedirectAttributes());
+        }
+    }
+}
