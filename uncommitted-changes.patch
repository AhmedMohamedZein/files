+package net.atos.mdi.transfermanagement.services.workflow.fund.support;
+
+import lombok.RequiredArgsConstructor;
+import net.atos.mdi.commons.util.CommonUtil;
+import net.atos.mdi.transfermanagement.constant.Constants;
+import net.atos.mdi.transfermanagement.constant.ErrorKeys;
+import net.atos.mdi.transfermanagement.constant.FundTransactionStage;
+import net.atos.mdi.transfermanagement.entities.TransferDetails;
+import net.atos.mdi.transfermanagement.repository.SequenceRepository;
+import net.atos.mdi.transfermanagement.repository.TransactionRepository;
+import net.atos.mdi.transfermanagement.repository.entities.TransactionHistory;
+import net.atos.mdi.transfermanagement.services.workflow.fund.step.FundWorkflowContext;
+import net.atos.mdi.transfermanagement.utils.TransferLimitsUtil;
+import net.atos.mdi.transfermanagement.web.client.model.MerchantProviderRequest;
+import org.springframework.stereotype.Component;
+
+import java.util.List;
+import java.util.regex.Pattern;
+
+@Component
+@RequiredArgsConstructor
+public class FundWorkflowTransactionSupport {
+
+    private final CommonUtil commonUtil;
+    private final SequenceRepository sequenceRepository;
+    private final TransactionRepository transactionRepository;
+    private final TransferLimitsUtil transferLimitsUtil;
+    private final FundingProviderResolver fundingProviderResolver;
+
+    public void initializeTransaction(FundWorkflowContext workflowContext) {
+        long transactionId = sequenceRepository.generateSequenceId(Constants.TRANSACTION_SEQUENCE);
+        String orderId = Constants.CUSTOMER_ORDER_PREFIXES + transactionId;
+        workflowContext.setOrderId(orderId);
+        workflowContext.setMerchantProviderRequest(MerchantProviderRequest.builder()
+                .transactionId(String.valueOf(transactionId))
+                .orderId(orderId)
+                .build());
+        TransactionHistory transactionHistory = fundingProviderResolver.resolve(workflowContext.getFundingProvider())
+                .createTransactionHistory(workflowContext, transactionId);
+        workflowContext.setTransactionHistory(transactionHistory);
+    }
+
+    public TransactionHistory retrieveTransactionHistory(String transactionId) {
+        if (transactionId == null || Pattern.compile("[a-zA-Z]").matcher(transactionId).find()) {
+            commonUtil.throwBusinessException(ErrorKeys.FUNDING_REQUEST_DETAILS_IS_EMPTY);
+        }
+        List<TransactionHistory> transactionHistoryList = transactionRepository.getTransactionById(null, Long.valueOf(transactionId));
+        if (transactionHistoryList.isEmpty()) {
+            commonUtil.throwBusinessException(ErrorKeys.FUNDING_REQUEST_DETAILS_IS_EMPTY);
+        }
+        if (transactionHistoryList.getFirst().getPayResponse() != null) {
+            commonUtil.throwBusinessException(ErrorKeys.TRANSACTION_ID_ALREADY_EXISTS);
+        }
+        return transactionHistoryList.getFirst();
+    }
+
+    public void updateTransferLimits(TransferDetails details, TransactionHistory transactionHistory) {
+        transactionHistory.setTransactionStage(FundTransactionStage.START_UPDATE_TRANSFER_LIMITS_REQUEST.name());
+        transferLimitsUtil.updateCustomerTransferLimits(details);
+        transactionHistory.setTransactionStage(FundTransactionStage.DONE_UPDATE_TRANSFER_LIMITS_REQUEST.name());
+    }
+
+    public void rollbackTransferLimits(TransferDetails details, TransactionHistory transactionHistory) {
+        transactionHistory.setTransactionStage(FundTransactionStage.START_TRANSFER_LIMITS_ROLL_BACK_REQUEST.name());
+        transferLimitsUtil.rollbackCustomerTransferLimits(details);
+        transactionHistory.setTransactionStage(FundTransactionStage.DONE_TRANSFER_LIMITS_ROLL_BACK_REQUEST.name());
+    }
+}
