+import net.atos.mdi.transfermanagement.web.client.model.CalculateServiceFeesRequest;
+import net.atos.mdi.transfermanagement.web.client.model.CalculateServiceFeesResponse;
+import net.atos.mdi.transfermanagement.web.client.ProductClient;
+import net.atos.mdi.transfermanagement.web.client.model.MerchantProviderRequest;
+import org.springframework.stereotype.Component;
+
+@Component
+@RequiredArgsConstructor
+public class FundWorkflowValidationSupport {
+
+    private final CommonUtil commonUtil;
+    private final TransferValidatorService transferValidatorService;
+    private final ProductClient productClient;
+    private final TransferUtils transferUtils;
+    private final TransferDetailsUtils transferDetailsUtils;
+    private final FundingProviderResolver fundingProviderResolver;
+
+    public void validateAmount(FundGeneralRequest request) {
+        transferUtils.validateAmount(request.getAmount());
+    }
+
+    public void validateFundingFees(FundGeneralRequest request) {
+        CalculateServiceFeesRequest calculateFees = CalculateServiceFeesRequest.builder()
+                .amount(request.getAmount())
+                .productId(request.getFees().getProductId())
+                .fee(Fee.FUNDING_FEES.name())
+                .currencyId(request.getCurrency())
+                .build();
+        CalculateServiceFeesResponse response = productClient.calculateFees(calculateFees);
+        if (response.getFeesAmount().compareTo(request.getFees().getFeeAmount()) != 0) {
+            commonUtil.throwBusinessException(ErrorKeys.CALCULATED_FEES_NOT_MATCHED);
+        }
+    }
+
+    public TransferDetails validateFundingEligibility(FundGeneralRequest request, ValidatorType validatorType, AuthType authType,
+                                                      FundingProvider fundingProvider) {
+        TransferRequest transferRequest = fundingProviderResolver.resolve(fundingProvider).buildTransferRequest(
+                FundWorkflowContext.builder()
+                        .fundingProvider(fundingProvider)
+                        .fundingRequest(request)
+                        .build()
+        );
+        TransferDetails transferDetails = transferDetailsUtils.createTransferDetails(transferRequest, validatorType, authType, null);
+        transferValidatorService.validateDefaultSetUp(transferDetails);
+        return transferDetails;
+    }
+
+    public void validateMerchantCallbackRequest(MerchantProviderRequest request) {
+        if (request.getResult() == null || !request.getResult().equals(Constants.BACKEND_SUCCESS_MESSAGE_KEY)
+                || request.getResponseGatewayRecommendation() == null
+                || !request.getResponseGatewayRecommendation().equals(Constants.PROCEED)) {
+            commonUtil.throwBusinessException(ErrorKeys.UNAUTHORIZED);
+        }
+    }
+}
