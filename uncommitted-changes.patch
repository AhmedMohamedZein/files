+                .firstName(customer.getFirstNameEN())
+                .middleName(customer.getMiddleNameEN())
+                .lastName(customer.getLastNameEN())
+                .build();
+        return AccountFunding.builder()
+                .recipient(recipient)
+                .senderType(Constants.PERSON)
+                .purpose(Constants.OTHER)
+                .senderIsRecipient(true)
+                .build();
+    }
+
+    public String orderDescription(Customer customer, String purpose) {
+        String description = customer.getIdentification().getValue() + "," + customer.getFirstName()
+                + "," + customer.getLastName() + "," + purpose;
+        return description.substring(0, Math.min(description.length(), 127));
+    }
+
+    public String currency(String currency) {
+        return currency == null || currency.isEmpty() ? defaultCurrency : currency;
+    }
+
+    public List<Reasons> reasons(String transferPurpose) {
+        return Collections.singletonList(new Reasons(transferPurpose));
+    }
+
+    public List<Charges> charges(Fees fees, String currency, String paymentOrderProductId) {
+        return Collections.singletonList(
+                Charges.builder()
+                        .chargeAmount(fees.getFeeAmount())
+                        .chargeCurrency(currency)
+                        .chargeName(paymentOrderProductId)
+                        .chargeType(paymentOrderProductId)
+                        .build()
+        );
+    }
+
+    public VoidRequest refundRequest(TransactionHistory transactionHistory, String orderId) {
+        VoidRequest voidRequest = VoidRequest.builder().build();
+        Transaction transaction = new Transaction();
+        transaction.setReference(orderId);
+        transaction.setTargetTransactionId("PAY_".concat(String.valueOf(transactionHistory.getTransactionId())));
+        voidRequest.setApiOperation("VOID");
+        voidRequest.setTransaction(transaction);
+        voidRequest.setCorrelationId(transactionHistory.getCorrelationId());
+        return voidRequest;
+    }
+}
