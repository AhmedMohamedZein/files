+import org.springframework.beans.factory.config.ConfigurableBeanFactory;
+import org.springframework.context.annotation.Scope;
+import org.springframework.stereotype.Component;
+
+@Component
+@Scope(ConfigurableBeanFactory.SCOPE_PROTOTYPE)
+public class PrepareFundCallbackStep extends FundFromExternalCardParentStep {
+
+    private final FundWorkflowTransactionSupport transactionSupport;
+    private final FundWorkflowValidationSupport validationSupport;
+    private final FundWorkflowResultSupport resultSupport;
+    private final FundUtils fundUtils;
+    private final CommonUtil commonUtil;
+
+    public PrepareFundCallbackStep(FundWorkflowTransactionSupport transactionSupport, FundWorkflowValidationSupport validationSupport, FundWorkflowResultSupport resultSupport,
+                                   FundUtils fundUtils, CommonUtil commonUtil) {
+        super("PrepareFundCallbackStep");
+        this.transactionSupport = transactionSupport;
+        this.validationSupport = validationSupport;
+        this.resultSupport = resultSupport;
+        this.fundUtils = fundUtils;
+        this.commonUtil = commonUtil;
+    }
+
+    @Override
+    public void execute() {
+        TransactionHistory transactionHistory = null;
+        try {
+            transactionHistory = transactionSupport.retrieveTransactionHistory(workflowContext.getMerchantProviderRequest().getTransactionId());
+            validationSupport.validateMerchantCallbackRequest(workflowContext.getMerchantProviderRequest());
+            fundUtils.setUpTransactionCorrelationId(transactionHistory.getCorrelationId());
+            fundUtils.decryptSource(transactionHistory.getFundInitPayerRequest(), transactionHistory.getCustomerId());
+            fundUtils.setUpCustomerId(transactionHistory);
+            workflowContext.setTransactionHistory(transactionHistory);
+            workflowContext.setFundingRequest(transactionHistory.getFundInitPayerRequest());
+        } catch (BackEndException e) {
+            commonUtil.logException(e);
+            resultSupport.handleBackEndException(workflowContext.getRedirectAttributes(), transactionHistory,
+                    workflowContext.getMerchantProviderRequest().getTransactionId());
+            throw e;
+        }
+    }
+}
