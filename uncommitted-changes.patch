+        order.setAmount(fundingRequest.getAmount().add(fundingRequest.getFees().getFeeAmount()));
+        order.setWalletProvider(provider().getPaymentGatewayValue());
+        order.setReference(context.getMerchantProviderRequest().getOrderId());
+        order.setPurchaseType(Constants.PURCHASE_TYPE);
+        order.setDescription(requestBuilder.orderDescription(customer, accountFunding.getPurpose()));
+
+        Transaction transaction = new Transaction();
+        transaction.setReference(context.getMerchantProviderRequest().getOrderId());
+        transaction.setSource("INTERNET");
+
+        PaymentRequest paymentRequest = PaymentRequest.builder().build();
+        paymentRequest.setAuthentication(new Authentication());
+        paymentRequest.setOrder(order);
+        paymentRequest.setSourceOfFunds(sourceOfFunds(fundingRequest));
+        paymentRequest.setApiOperation("PAY");
+        paymentRequest.setTransaction(transaction);
+        paymentRequest.setCorrelationId(transactionHistory.getCorrelationId());
+        return paymentRequest;
+    }
+
+    @Override
+    public PaymentRequest createStoredPaymentRequest(FundWorkflowContext context, PaymentRequest paymentRequest) {
+        return paymentRequest;
+    }
+
+    @Override
+    public PaymentResponse callPayment(PaymentGateWayClient paymentGateWayClient, String merchantId,
+                                       MerchantProviderRequest merchantProviderRequest, PaymentRequest paymentRequest) {
+        return paymentGateWayClient.callPaymentViaWalletProvider(
+                merchantProviderRequest.getOrderId(),
+                Constants.PAYMENT_PROCESS_PREFIX.concat(merchantProviderRequest.getTransactionId()),
+                merchantId,
+                paymentRequest
+        );
+    }
+
+    @Override
+    public ClientInternalTransferRequest createInternalTransferRequest(FundWorkflowContext context) {
+        FundUsingApplePayRequest fundingRequest = request(context);
+        TransferDetails details = context.getTransferDetails();
+        String suspendAccount = transferManagementConfig.getCoreSuspendAccounts().get(TransferType.FUND_MY_ACCOUNT_FROM_EXTERNAL_CARD.getSuspendAccount());
+        String paymentOrderProductId = transferManagementConfig.getPaymentOrderProductId().get(TransferType.FUND_MY_ACCOUNT_FROM_EXTERNAL_CARD.getPaymentOrder());
+        String waiveCharge = waiveCharge(fundingRequest);
+        List<Reasons> reasons = requestBuilder.reasons(fundingRequest.getTransferPurpose());
+        List<Narratives> narratives = transferObjectBuilder.createNarratives(details);
+        List<Charges> charges = requestBuilder.charges(fundingRequest.getFees(), fundingRequest.getCurrency(), paymentOrderProductId);
+        return ClientInternalTransferRequest.builder()
+                .apiChannel(ThreadContext.get(net.atos.mdi.commons.constants.Constants.USER_AGENT_CHANNEL_VAR_NAME))
+                .amount(Double.parseDouble(String.valueOf(fundingRequest.getAmount())))
+                .paymentCurrencyId(fundingRequest.getCurrency())
+                .paymentOrderProductId(paymentOrderProductId)
+                .debitAccountId(suspendAccount)
+                .narratives(narratives)
+                .reasons(reasons)
+                .creditAccountId(fundingRequest.getDestinationIdentifier())
+                .charges(charges)
+                .debitChargeImposed(waiveCharge == null ? Constants.WAIVE_CHARGE_KEY : null)
+                .purpose(fundingRequest.getTransferPurpose())
+                .waiveCharge(waiveCharge)
+                .build();
+    }
+
+    @Override
+    public ClientTransferResponse callInternalTransfer(CoreClient coreClient, ClientInternalTransferRequest request) {
+        return coreClient.transfer(request);
+    }
+
+    @Override
+    public VoidRequest createRefundRequest(FundWorkflowContext context) {
+        return requestBuilder.refundRequest(context.getTransactionHistory(), context.getMerchantProviderRequest().getOrderId());
+    }
+
+    @Override
+    public PaymentResponse callRefund(PaymentGateWayClient paymentGateWayClient, String merchantId,
+                                      MerchantProviderRequest merchantProviderRequest, VoidRequest refundRequest) {
+        return paymentGateWayClient.callVoidViaWalletProvider(
+                merchantProviderRequest.getOrderId(),
+                Constants.REFUND_PROCESS_PREFIX.concat(merchantProviderRequest.getTransactionId()),
+                merchantId,
+                refundRequest
+        );
+    }
+
+    private SourceOfFunds sourceOfFunds(FundUsingApplePayRequest request) throws JsonProcessingException {
+        Card card = new Card();
+        DevicePayment devicePayment = new DevicePayment();
+        devicePayment.setPaymentToken(objectMapper.writeValueAsString(request.getAppleData()));
+        card.setDevicePayment(devicePayment);
+        Provided provided = new Provided();
+        provided.setCard(card);
+        SourceOfFunds sourceOfFunds = new SourceOfFunds();
+        sourceOfFunds.setProvided(provided);
+        sourceOfFunds.setType("CARD");
+        return sourceOfFunds;
+    }
+
+    private String waiveCharge(FundUsingApplePayRequest request) {
+        if (request.getFees() != null && BigDecimal.ZERO.equals(request.getFees().getFeeAmount())) {
+            return Constants.WAIVE_CHARGE_KEY;
+        }
+        return null;
+    }
+
+    private FundUsingApplePayRequest request(FundWorkflowContext context) {
+        if (context.getFundingRequest() instanceof FundUsingApplePayRequest applePayRequest) {
+            return applePayRequest;
+        }
+        throw new IllegalArgumentException("Unsupported request type for Apple Pay funding");
+    }
+}
