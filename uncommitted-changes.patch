+package net.atos.mdi.transfermanagement.services.workflow.fund.handler;
+
+import lombok.RequiredArgsConstructor;
+import net.atos.mdi.commons.util.CommonUtil;
+import net.atos.mdi.commons.workflow.WorkflowExceptionHandler;
+import net.atos.mdi.transfermanagement.constant.FundStatus;
+import net.atos.mdi.transfermanagement.repository.TransactionRepository;
+import net.atos.mdi.transfermanagement.services.workflow.fund.step.FundWorkflowContext;
+import net.atos.mdi.transfermanagement.services.workflow.fund.step.RefundFundPaymentStep;
+import net.atos.mdi.transfermanagement.services.workflow.fund.step.RollbackFundTransferLimitsStep;
+
+@RequiredArgsConstructor
+public class FundPaymentFailureHandler implements WorkflowExceptionHandler {
+
+    private final FundWorkflowContext workflowContext;
+    private final RollbackFundTransferLimitsStep rollbackFundTransferLimitsStep;
+    private final RefundFundPaymentStep refundFundPaymentStep;
+    private final TransactionRepository transactionRepository;
+    private final CommonUtil commonUtil;
+
+    @Override
+    public void handleException(RuntimeException e) {
+        commonUtil.logException(e);
+        if (workflowContext.getTransactionHistory() != null) {
+            workflowContext.getTransactionHistory().setTransactionStatus(FundStatus.FAILED.name());
+            if (workflowContext.isPaymentCalled()) {
+                executeCompensation(rollbackFundTransferLimitsStep);
+                executeCompensation(refundFundPaymentStep);
+            } else if (workflowContext.isTransferLimitsUpdated()) {
+                executeCompensation(rollbackFundTransferLimitsStep);
+            }
+            transactionRepository.saveTransaction(workflowContext.getTransactionHistory());
+        }
+        throw e;
+    }
+
+    private void executeCompensation(net.atos.mdi.commons.workflow.WorkflowStep step) {
+        try {
+            step.setWorkflowContext(workflowContext);
+            step.execute();
+        } catch (RuntimeException compensationException) {
+            commonUtil.logException(compensationException);
+        }
+    }
+}
