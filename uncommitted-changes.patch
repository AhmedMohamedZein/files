+package net.atos.mdi.transfermanagement.services.workflow.fund.support;
+
+import lombok.RequiredArgsConstructor;
+import net.atos.mdi.transfermanagement.constant.FundingProvider;
+import net.atos.mdi.transfermanagement.services.workflow.fund.handler.FundingProviderHandler;
+import org.springframework.stereotype.Component;
+
+import java.util.List;
+import java.util.Objects;
+
+@Component
+@RequiredArgsConstructor
+class FundingProviderResolver {
+
+    private final List<FundingProviderHandler> fundingProviderHandlers;
+
+    FundingProviderHandler resolve(FundingProvider fundingProvider) {
+        return fundingProviderHandlers.stream()
+                .filter(handler -> Objects.equals(handler.provider(), fundingProvider))
+                .findFirst()
+                .orElseThrow(() -> new IllegalArgumentException("Unsupported funding provider: " + fundingProvider));
+    }
+}
