+    private void stubWorkflowExecuting(Consumer<FundWorkflowContext> executeAction) {
+        when(workflowStepFactory.getWorkflowStep(eq(DefaultWorkflow.class), eq(WorkflowFundServiceImplTest.CALLBACK_WORKFLOW), any(FundWorkflowContext.class)))
+                .thenAnswer(invocation -> {
+                    lastWorkflowContext = invocation.getArgument(2, FundWorkflowContext.class);
+                    return new DefaultWorkflow(WorkflowFundServiceImplTest.CALLBACK_WORKFLOW, lastWorkflowContext) {
+                        @Override
+                        public void execute() {
+                            executeAction.accept(lastWorkflowContext);
+                        }
+                    };
+                });
+    }
