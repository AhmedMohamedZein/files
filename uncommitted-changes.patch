+package net.atos.mdi.transfermanagement.services.workflow.fund.support;
+
+import com.fasterxml.jackson.core.JsonProcessingException;
+import lombok.RequiredArgsConstructor;
+import net.atos.mdi.transfermanagement.constant.FundStatus;
+import net.atos.mdi.transfermanagement.constant.FundTransactionStage;
+import net.atos.mdi.transfermanagement.entities.XDeviceFingerprint;
+import net.atos.mdi.transfermanagement.repository.entities.TransactionHistory;
+import net.atos.mdi.transfermanagement.services.workflow.fund.step.FundWorkflowContext;
+import net.atos.mdi.transfermanagement.services.workflow.fund.handler.FundingProviderHandler;
+import net.atos.mdi.transfermanagement.utils.FundUtils;
+import net.atos.mdi.transfermanagement.utils.transfers.TransferObjectBuilder;
+import net.atos.mdi.transfermanagement.web.api.vm.FundInitPayerRequest;
+import net.atos.mdi.transfermanagement.web.client.CoreClient;
+import net.atos.mdi.transfermanagement.web.client.PaymentGateWayClient;
+import net.atos.mdi.transfermanagement.web.client.model.ClientInternalTransferRequest;
+import net.atos.mdi.transfermanagement.web.client.model.ClientTransferResponse;
+import net.atos.mdi.transfermanagement.web.client.model.MerchantProviderRequest;
+import net.atos.mdi.transfermanagement.web.client.model.PaymentResponse;
+import net.atos.mdi.transfermanagement.web.api.vm.TransferResponse;
+import net.atos.mdi.transfermanagement.web.client.model.payment.AuthenticationPayerRequest;
+import net.atos.mdi.transfermanagement.web.client.model.payment.AuthenticationPayerResponse;
+import net.atos.mdi.transfermanagement.web.client.model.payment.InitAuthenticationRequest;
+import net.atos.mdi.transfermanagement.web.client.model.payment.InitAuthenticationResponse;
+import net.atos.mdi.transfermanagement.web.client.model.payment.PaymentRequest;
+import net.atos.mdi.transfermanagement.web.client.model.payment.VoidRequest;
+import org.springframework.beans.factory.annotation.Value;
+import org.springframework.stereotype.Component;
+
+@Component
+@RequiredArgsConstructor
+public class FundWorkflowExecutionSupport {
+
+    @Value("${app.config.integration.domain.transfer-management.payment-gateway.config.merchantId}")
+    private String merchantId;
+
+    private final FundUtils fundUtils;
+    private final PaymentGateWayClient paymentGateWayClient;
+    private final CoreClient coreClient;
+    private final TransferObjectBuilder transferObjectBuilder;
+    private final FundingProviderResolver fundingProviderResolver;
+
+    public void initAuthentication(FundInitPayerRequest request, String orderId, TransactionHistory transactionHistory) {
+        InitAuthenticationRequest initAuthenticationRequest = fundUtils.createInitAuthenticationRequest(request, transactionHistory.getCorrelationId());
+        InitAuthenticationRequest initAuthenticationSecureRequest = fundUtils.encryptedInitAuthentication(initAuthenticationRequest);
+        transactionHistory.setIntRequest(initAuthenticationSecureRequest);
+        transactionHistory.setTransactionStage(FundTransactionStage.START_INIT_AUTHENTICATION_REQUEST.name());
+        InitAuthenticationResponse response = paymentGateWayClient.callInitAuthenticate(orderId, String.valueOf(transactionHistory.getTransactionId()), merchantId, initAuthenticationRequest);
+        transactionHistory.setIntResponse(response);
+        transactionHistory.setTransactionStage(FundTransactionStage.DONE_INIT_AUTHENTICATION_REQUEST.name());
+        fundUtils.checkResponse(response);
+    }
+
+    public String authenticatePayer(FundInitPayerRequest request, XDeviceFingerprint fingerprint, String language,
+                                    String orderId, TransactionHistory transactionHistory) {
+        AuthenticationPayerRequest authenticationPayerRequest = fundUtils.createAuthenticationPayerRequest(language, fingerprint.getBrowser(),
+                fingerprint.getHeight(), fingerprint.getWidth(), fingerprint.getTimeZone(), request);
+        authenticationPayerRequest.setTransactionId(String.valueOf(transactionHistory.getTransactionId()));
+        AuthenticationPayerRequest secureRequest = fundUtils.encryptedAuthenticationPayer(authenticationPayerRequest);
+        transactionHistory.setAuthRequest(secureRequest);
+        transactionHistory.setTransactionStage(FundTransactionStage.START_AUTH_PAYER_REQUEST.name());
+        AuthenticationPayerResponse response = paymentGateWayClient.callAuthenticatePayer(orderId, String.valueOf(transactionHistory.getTransactionId()), merchantId, authenticationPayerRequest);
+        transactionHistory.setAuthResponse(response);
+        transactionHistory.setTransactionStage(FundTransactionStage.DONE_AUTH_PAYER_REQUEST.name());
+        fundUtils.checkResponse(response);
+        return response.getAuthentication().getRedirectHtml();
+    }
+
+    public void callFundingPayment(FundWorkflowContext workflowContext) throws JsonProcessingException {
+        TransactionHistory transactionHistory = workflowContext.getTransactionHistory();
+        MerchantProviderRequest request = workflowContext.getMerchantProviderRequest();
+        FundingProviderHandler handler = fundingProviderResolver.resolve(workflowContext.getFundingProvider());
+        PaymentRequest paymentRequest = handler.createPaymentRequest(workflowContext);
+        PaymentRequest securePaymentRequest = handler.createStoredPaymentRequest(workflowContext, paymentRequest);
+        transactionHistory.setPayRequest(securePaymentRequest);
+        transactionHistory.setTransactionStage(FundTransactionStage.START_PAYMENT_REQUEST.name());
+        PaymentResponse paymentResponse = handler.callPayment(paymentGateWayClient, merchantId, request, paymentRequest);
+        transactionHistory.setPayResponse(paymentResponse);
+        fundUtils.checkResponse(paymentResponse);
+        transactionHistory.setTransactionStage(FundTransactionStage.DONE_PAYMENT_REQUEST.name());
+    }
+
+    public void callInternalFund(FundWorkflowContext workflowContext) {
+        TransactionHistory transactionHistory = workflowContext.getTransactionHistory();
+        transactionHistory.setTransactionStage(FundTransactionStage.START_INTERNAL_TRANSFER_REQUEST.name());
+        FundingProviderHandler handler = fundingProviderResolver.resolve(workflowContext.getFundingProvider());
+        ClientInternalTransferRequest request = handler.createInternalTransferRequest(workflowContext);
+        transactionHistory.setTransferSuspendAccountRequest(request);
+        ClientTransferResponse response = handler.callInternalTransfer(coreClient, request);
+        TransferResponse transferResponse = transferObjectBuilder.transferResponseMapping(response);
+        transactionHistory.setTransferSuspendAccountResponse(transferResponse);
+        transactionHistory.setTransactionStage(FundTransactionStage.DONE_INTERNAL_TRANSFER_REQUEST.name());
+    }
+
+    public void callRefund(FundWorkflowContext workflowContext) {
+        TransactionHistory transactionHistory = workflowContext.getTransactionHistory();
+        MerchantProviderRequest request = workflowContext.getMerchantProviderRequest();
+        FundingProviderHandler handler = fundingProviderResolver.resolve(workflowContext.getFundingProvider());
+        VoidRequest refundRequest = handler.createRefundRequest(workflowContext);
+        transactionHistory.setRefundRequest(refundRequest);
+        transactionHistory.setTransactionStage(FundTransactionStage.START_REFUND_REQUEST.name());
+        PaymentResponse refundResponse = handler.callRefund(paymentGateWayClient, merchantId, request, refundRequest);
+        transactionHistory.setRefundResponse(refundResponse);
+        transactionHistory.setTransactionStage(FundTransactionStage.DONE_REFUND_REQUEST.name());
+        transactionHistory.setTransactionStatus(FundStatus.REFUNDED.name());
+    }
+}
