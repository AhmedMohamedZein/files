+import net.atos.mdi.transfermanagement.constant.FundWorkflowOperation;
+import net.atos.mdi.transfermanagement.services.workflow.fund.support.FundWorkflowResultSupport;
+import net.atos.mdi.transfermanagement.web.api.vm.FundingResponse;
+import org.springframework.beans.factory.config.ConfigurableBeanFactory;
+import org.springframework.context.annotation.Scope;
+import org.springframework.stereotype.Component;
+
+@Component
+@Scope(ConfigurableBeanFactory.SCOPE_PROTOTYPE)
+public class CompleteFundTransactionStep extends FundFromExternalCardParentStep {
+
+    private final FundWorkflowResultSupport resultSupport;
+
+    public CompleteFundTransactionStep(FundWorkflowResultSupport resultSupport) {
+        super("CompleteFundTransactionStep");
+        this.resultSupport = resultSupport;
+    }
+
+    @Override
+    public void execute() {
+        workflowContext.getTransactionHistory().setTransactionStatus(FundStatus.COMPLETED.name());
+        if (workflowContext.getOperation() == FundWorkflowOperation.CALLBACK_PAYMENT) {
+            resultSupport.successfulTransaction(workflowContext.getRedirectAttributes(), workflowContext.getTransactionHistory());
+        } else if (workflowContext.getOperation() == FundWorkflowOperation.PROVIDER_PAYMENT) {
+            workflowContext.setFundingResponse(FundingResponse.builder()
+                    .transactionId(String.valueOf(workflowContext.getTransactionHistory().getTransactionId()))
+                    .amount(workflowContext.getFundingRequest().getAmount())
+                    .referenceNumber(workflowContext.getTransactionHistory().getTransferSuspendAccountResponse().getReferenceNumber())
+                    .transactionReference(workflowContext.getTransactionHistory().getTransferSuspendAccountResponse().getTransactionReference())
+                    .maskedCardNumber(resultSupport.maskedCardNumber(workflowContext.getTransferDetails()))
+                    .build());
+        }
+    }
