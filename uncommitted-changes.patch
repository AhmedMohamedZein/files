+        stubStep(SaveFundTransactionStep.class);
+        stubStep(RollbackFundTransferLimitsStep.class);
+        stubStep(RefundFundPaymentStep.class);
+        return prepareStep;
+    }
+
+    private <T extends WorkflowStep> T stubStep(Class<T> stepType) {
+        T step = mock(stepType);
+        lenient().when(step.shouldExecute()).thenReturn(true);
+        lenient().when(step.isAsync()).thenReturn(false);
+        when(workflowStepFactory.getWorkflowStep(stepType)).thenReturn(step);
+        return step;
+    }
